{
  "name": "agentplane-attestations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hackathon MVP for generating and verifying agent work attestations.",
  "scripts": {
    "extract:agentplane:task": "node src/cli.mjs extract --task-id 202603131024-THDVQ1 --output artifacts/extracted-runtime.json",
    "adapt:agentplane:pass": "node src/cli.mjs adapt --adapter agentplane --input examples/agentplane-runtime-passing.json --output artifacts/passing-bundle.json",
    "adapt:agentplane:fail": "node src/cli.mjs adapt --adapter agentplane --input examples/agentplane-runtime-failing.json --output artifacts/failing-bundle.json",
    "adapt:agentplane:task": "node src/cli.mjs adapt --adapter agentplane --task-id 202603131024-THDVQ1 --output artifacts/extracted-bundle.json",
    "attest:pass": "node src/cli.mjs generate --input examples/passing-bundle.json --output artifacts/passing-attestation.json",
    "attest:fail": "node src/cli.mjs generate --input examples/failing-bundle.json --output artifacts/failing-attestation.json",
    "verify:pass": "node src/cli.mjs verify --input artifacts/passing-attestation.json --expect trusted",
    "verify:fail": "node src/cli.mjs verify --input artifacts/failing-attestation.json --expect reject",
    "report:pass": "node src/cli.mjs render --input artifacts/passing-attestation.json --output artifacts/passing-report.html",
    "report:fail": "node src/cli.mjs render --input artifacts/failing-attestation.json --output artifacts/failing-report.html",
    "demo": "node src/cli.mjs demo",
    "test": "node --test"
  }
}
